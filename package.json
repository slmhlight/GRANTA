  "scripts": {
    "dev": "vite --host",
    "build:data": "node scripts/build-from-registry.mjs",
    "build:stats": "node scripts/build-property-stats.mjs",
    "build:profiles": "node scripts/build-process-profiles.mjs",
    "build:wiki": "node scripts/build-wiki-index.mjs",
    "build:registry": "node scripts/build-materials.mjs && node scripts/build-registry.mjs",
    "audit:registry": "node scripts/audit-registry.mjs",
    "audit:sample": "node scripts/audit-random-sample.mjs",
